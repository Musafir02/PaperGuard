{
  "functions": {
    "api/index.py": {
      "excludeFiles": "ops-webapp/**|backend/uploads/**|uploads/**|*.png|*.pdf|*.jpg"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "api/index.py"
    },
    {
      "source": "/:path*",
      "destination": "/ops-webapp/:path*"
    }
  ]
}
