{
  "builds": [
    {
      "src": "ops-webapp/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "ops-webapp/$1"
    }
  ],
  "functions": {
    "backend/app/main.py": {
      "excludeFiles": "ops-webapp/**|backend/uploads/**|uploads/**|*.png|*.pdf|*.jpg"
    }
  }
}
